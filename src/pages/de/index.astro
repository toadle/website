---
import { getCollection } from "astro:content";
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import { i18n } from "../../i18n";
import indexHero from "../../assets/index-hero.png";

const lang = "de";
const t = i18n[lang];
const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<ContainerLayout
  title={t.siteTitle}
  description={t.siteDescription}
  lang={lang}
  padTop
>
  <section class="hero">
    <div class="hero-text">
      {t.home.kicker && <p class="kicker">{t.home.kicker}</p>}
      {t.home.headline && <h1>{t.home.headline}</h1>}
      <p class="intro">
        <a class="name-link" href="/de/about">Tim Adler</a> {t.home.intro}
      </p>
      <div class="cta">
        <a class="cta-link" href="/de/about">
          {t.home.ctaPrimary}
        </a>
        <a class="cta-link" href="/de/leistungen">
          {t.home.ctaSecondary}
        </a>
      </div>
    </div>
    <img
      class="hero-image"
      src={indexHero.src}
      width={indexHero.width}
      height={indexHero.height}
      alt="Tim Adler bei der Arbeit"
      loading="eager"
      decoding="async"
    />
  </section>

  <section class="blog">
    <div class="blog-header">
      <h2>{t.home.blogTitle}</h2>
      <a href="/de/blog">{t.home.blogLink}</a>
    </div>
    <ul class="blog-list">
      {posts.map((post) => (
        <li>
          <a href={`/de/blog/${post.id}/`}>
            <span class="title">{post.data.title}</span>
            <span class="meta">
              {post.data.pubDate.toLocaleDateString("de-DE", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</ContainerLayout>

<style>
  .hero {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
    padding-block-end: var(--space-3xl);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-s);
    object-fit: cover;
  }

  .kicker {
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gray-10);
  }

  .intro {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    letter-spacing: -0.015em;
  }

  .name-link {
    font-weight: 600;
    text-decoration-thickness: 0.1em;
    text-underline-offset: 0.08em;
    text-decoration-color: var(--gray-7);
    text-decoration-skip-ink: none;
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    margin-top: var(--space-s);
  }

  .cta-link {
    font-weight: var(--font-weight-bold);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .blog {
    padding-block: var(--space-2xl) var(--space-3xl);
    display: grid;
    gap: var(--space-m);
  }

  .blog-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .blog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-s);
  }

  .blog-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    padding-block: var(--space-xs);
    border-bottom: 1px solid var(--gray-4);
  }

  .blog-list li:last-child a {
    border-bottom: none;
  }

  .blog-list .title {
    font-weight: var(--font-weight-bold);
  }

  .blog-list .meta {
    font-size: var(--step--1);
    color: var(--gray-10);
  }
</style>
