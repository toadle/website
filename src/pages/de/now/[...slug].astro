---
import { type CollectionEntry } from "astro:content";
import NowDetailPage from "../../../layouts/NowDetailPage.astro";
import { getNowDetailPaths } from "../../../lib/staticPaths";

export const getStaticPaths = () => getNowDetailPaths("de");

type Props = {
  entry: CollectionEntry<"now">;
  languageSwitchHref: string;
};

const { entry, languageSwitchHref } = Astro.props;
---
<NowDetailPage entry={entry} lang="de" languageSwitchHref={languageSwitchHref} />
