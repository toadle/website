---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import WorkAccordionList from "../../components/WorkAccordionList.astro";
import { i18n } from "../../i18n";
import { projectEntries } from "../../content/work";

const lang = "de";
const t = i18n[lang];
---

<ContainerLayout
  title={`Leistungen · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>Leistungen</h1>
    <p class="lead">Digitale Produkte schneller auf den Punkt bringen.</p>
    <p>
      Ich unterstuetze Teams dabei, aus Ideen belastbare digitale Produkte zu machen:
      mit klarem Fokus, pragmatischer Technik und einem Setup, das auch unter
      echten Zeit- und Budgetbedingungen funktioniert.
    </p>
    <p>
      Ob Produkt-Neustart, kritische Delivery-Phase oder technische Neuordnung:
      ich verbinde Produktdenken und Engineering, reduziere Komplexitaet und schaffe
      in kurzer Zeit sichtbare Fortschritte.
    </p>

    <ContentSection title="Ausgewaehlte Kundenprojekte">
      <WorkAccordionList lang={lang} items={projectEntries} />
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .lead {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    max-width: 24ch;
    margin: 0;
  }

  .page > p:not(.lead) {
    margin: 0;
    max-width: 66ch;
    line-height: var(--line-height-snug);
  }

  .page :global(.content-section) {
    padding-top: var(--space-xl);
  }

  .page :global(.content-section h2) {
    font-size: var(--step-2);
  }
</style>
