---
import { getCollection, render } from "astro:content";
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import { i18n } from "../../i18n";
import { isEntryInLocale } from "../../lib/contentLocale";
import { sortNowEntries } from "../../lib/nowImport/sortNowEntries";
import NowRating from "../../components/NowRating.astro";
import Richlink from "../../components/Richlink.astro";

const lang = "de";
const t = i18n[lang];

const rawEntries = sortNowEntries(
  (await getCollection("now")).filter((entry) =>
    isEntryInLocale(entry.id, lang, entry.data.lang)
  )
);

const entries = await Promise.all(
  rawEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const toEmbedUrl = (url: string) => {
  try {
    const parsed = new URL(url);
    if (parsed.hostname.includes("youtube.com")) {
      const id = parsed.searchParams.get("v");
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
    if (parsed.hostname.includes("youtu.be")) {
      const id = parsed.pathname.replace("/", "");
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
  } catch (err) {
    return "";
  }
  return "";
};

const formatNowDate = (date: Date) =>
  date.toLocaleDateString("de-DE", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
---

<ContainerLayout
  title={`${t.now.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <header class="intro">
      <h1>{t.now.title}</h1>
      <p class="lead">{t.now.lead}</p>
    </header>

    <ol class="timeline">
      {entries.map(({ entry, Content }) => (
        <li>
          <time datetime={entry.data.date.toISOString()}>{formatNowDate(entry.data.date)}</time>
          {entry.data.rating && <NowRating rating={entry.data.rating} label="Meine Bewertung" />}
          {entry.data.quote && <blockquote>{entry.data.quote}</blockquote>}
          {entry.body?.trim() && (
            <div class="body">
              <Content />
            </div>
          )}
          {entry.data.reviewText && <p class="opinion">{entry.data.reviewText}</p>}
          {entry.data.opinion && <p class="opinion">{entry.data.opinion}</p>}
          {entry.data.richlink && <Richlink link={entry.data.richlink} />}
          {entry.data.youtube && (
            <div class="embed">
              <iframe
                src={toEmbedUrl(entry.data.youtube)}
                title="YouTube video"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          )}
          {entry.data.image && (
            <figure>
              <img
                src={entry.data.image.src}
                alt={entry.data.image.alt}
                loading="lazy"
              />
            </figure>
          )}
        </li>
      ))}
    </ol>
  </section>
</ContainerLayout>

<style>
  :global(body) {
    background-color: var(--gray-1);
    color: var(--gray-12);
  }

  :global(a) {
    color: inherit;
    text-decoration-color: var(--gray-7);
  }

  .page {
    display: grid;
    gap: var(--space-2xl);
  }

  .lead {
    font-size: var(--step-1);
    max-width: 60ch;
    color: var(--gray-10);
  }

  .intro {
    display: grid;
    gap: var(--space-xs);
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-l);
    position: relative;
  }

  .timeline::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 10px;
    width: 2px;
    background: var(--gray-4);
    border-radius: 999px;
  }

  .timeline li {
    position: relative;
    padding-left: var(--space-2xl);
    display: grid;
    gap: var(--space-xs);
  }

  .timeline li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gray-7);
    border: 2px solid var(--gray-2);
    box-shadow: 0 0 0 2px var(--gray-1);
  }

  .timeline time {
    font-size: var(--step--1);
    color: var(--gray-10);
    letter-spacing: 0.02em;
  }

  .timeline p {
    margin: 0;
    font-size: var(--step-0);
    max-width: 70ch;
  }

  .timeline .body :global(p) {
    margin: 0;
    font-size: var(--step-0);
    max-width: 70ch;
  }

  .timeline blockquote {
    margin: 0;
    padding-left: var(--space-m);
    border-left: 2px solid var(--gray-6);
    color: var(--gray-12);
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .timeline .opinion {
    color: var(--gray-10);
    font-style: italic;
  }

  .timeline figure {
    margin: 0;
  }

  .timeline img {
    width: 100%;
    border-radius: var(--radius-m);
    border: 1px solid var(--gray-4);
    display: block;
  }

  .embed {
    position: relative;
    padding-top: 56.25%;
    border-radius: var(--radius-m);
    border: 1px solid var(--gray-4);
    overflow: hidden;
    background: var(--gray-2);
  }

  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
