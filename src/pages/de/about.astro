---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import { i18n } from "../../i18n";
import portrait from "../../assets/legacy/ich.png";

const lang = "de";
const t = i18n[lang];

const capabilitySections = [
  {
    title: "Frontend",
    items: [
      "HTML",
      "CSS",
      "SASS",
      "JavaScript",
      "React",
      "React Native",
      "Redux",
      "SwiftUI",
      "JAMStack",
      "Microformats",
      "jQuery",
      "Bootstrap",
    ],
  },
  {
    title: "Backend",
    items: [
      "Ruby On Rails",
      "Ruby",
      "Golang",
      "Swift",
      "GraphQL",
      "JSONAPI",
      "Node.js",
      "Python",
      "Django",
      "Docker",
      "Amazon Web Services",
    ],
  },
  {
    title: "Datenbanken",
    items: ["MySQL", "Postgres", "Redis", "Oracle", "ElasticSearch"],
  },
  {
    title: "Drittanbieter",
    items: [
      "Github",
      "Stripe",
      "CircleCI",
      "Github Actions",
      "SalesForce",
      "Contentful",
      "GSuite",
      "AWS",
      "Teachable",
      "Recurly",
      "RevenueCat",
      "Facebook Ads",
      "Google Ads",
      "AppStore",
      "Zapier",
      "Mailchimp",
      "Mandrill",
      "Braze",
    ],
  },
  {
    title: "Methoden",
    items: [
      "Git",
      "TDD",
      "SCRUM",
      "Design Thinking",
      "Rapid Prototyping",
      "Lean Startup",
      "Business Model Canvas",
    ],
  },
];

const career = [
  {
    role: "CTO",
    years: "2020 - heute",
    organization: "Chefkoch",
    url: "https://www.chefkoch.de",
  },
  {
    role: "Managing Director",
    years: "2019 - 2020",
    organization: "Innovation Lab",
    url: "https://greenhouse.media",
  },
  {
    role: "Head of Technology",
    years: "2017 - 2019",
    organization: "Innovation Lab",
    url: "https://greenhouse.media",
  },
  {
    role: "Head of Development",
    years: "2013 - 2017",
    organization: "Startup Inkubator / Company Builder",
    url: "https://www.hanseventures.com",
  },
  {
    role: "Projektleiter",
    years: "2011 - 2012",
    organization: "Operations / Digital",
    url: "https://www.guj.de",
  },
  {
    role: "Produktmanager",
    years: "2010",
    organization: "iPad Version Nachrichten Magazin",
    url: "https://www.stern.de",
  },
  {
    role: "Management Trainee",
    years: "2009",
    organization: "Internationaler Verlag",
    url: "https://www.guj.de",
  },
  {
    role: "Web Developer",
    years: "2006 - 2008",
    organization: "Werbeagentur",
  },
  {
    role: "Designer, Entwickler",
    years: "2006 - 2008",
    organization: "Selbststaendig",
  },
  {
    role: "Java-Entwickler",
    years: "2004",
    organization: "Direktmarketing-Unternehmen",
    url: "https://www.az-direct.com",
  },
];
---

<ContainerLayout
  title={`${t.about.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.about.title}</h1>
    <img class="portrait" src={portrait.src} width={portrait.width} height={portrait.height} alt="Portraet von Tim Adler" />
    <p class="lead">
      Seit mehr als 15 Jahren arbeite ich als Designer, Entwickler und Technik-Manager.
      Von den ersten Schritten als Junior-Programmierer bis zur Verantwortung als CTO
      habe ich in unterschiedlichen Rollen immer hands-on in der technischen
      Produktentwicklung gearbeitet.
    </p>
    <p>
      Ich entscheide nicht nur mit, ich packe auch in der Umsetzung an: vom Programmieren
      bis zum taeglichen Status-Meeting. In allen Rollen war ich Uebersetzer zwischen
      Geschaeftsanforderungen und technischen Rahmenbedingungen.
    </p>

    <ContentSection title="Das kann ich" kicker="Kompetenzen">
      <div class="capability-grid">
        {capabilitySections.map((section) => (
          <section class="capability-section">
            <h3>{section.title}</h3>
            <ul>
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </ContentSection>

    <ContentSection title="Berufserfahrung" kicker="Daher komme ich">
      <ol class="timeline">
        {career.map((entry) => (
          <li>
            <article>
              <header>
                <h3>{entry.role}</h3>
                <span>{entry.years}</span>
              </header>
              {
                entry.url ? (
                  <a href={entry.url} target="_blank" rel="noopener noreferrer">
                    {entry.organization}
                  </a>
                ) : (
                  <p>{entry.organization}</p>
                )
              }
            </article>
          </li>
        ))}
      </ol>
    </ContentSection>

    <ContentSection title="Ausbildung">
      <ul class="education">
        <li>
          <strong>Diplom Medienwissenschaften</strong>
          <span>2004 - 2008</span>
          <p>Universitaet Paderborn</p>
        </li>
        <li>
          <strong>Certified SCRUM Master</strong>
          <span>2015</span>
          <p>IT agile</p>
        </li>
        <li>
          <strong>Fachinformatiker</strong>
          <span>2001 - 2004</span>
          <p>Internationaler Medienkonzern</p>
        </li>
      </ul>
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-xl);
    max-width: 72ch;
    margin-inline: auto;
  }

  .lead {
    font-size: var(--step-1);
    max-width: 62ch;
  }

  .portrait {
    width: min(100%, 22rem);
    height: auto;
    border-radius: var(--radius-m);
  }

  .capability-grid {
    display: grid;
    gap: var(--space-l);
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: var(--space-2xs);
  }

  .capability-section {
    display: grid;
    gap: var(--space-xs);
  }

  .capability-section h3 {
    margin: 0;
  }

  .timeline {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-m);
  }

  .timeline article {
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: var(--space-s);
  }

  .timeline header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .timeline h3 {
    margin: 0;
  }

  .timeline a,
  .timeline p {
    margin: var(--space-2xs) 0 0;
  }

  .education {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-m);
  }

  .education li {
    display: grid;
    gap: var(--space-2xs);
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: var(--space-s);
  }

  .education p,
  .education span,
  .timeline span {
    color: var(--color-text-muted);
  }
</style>
