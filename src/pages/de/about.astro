---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import { i18n } from "../../i18n";
import portrait from "../../assets/legacy/ich.png";

const lang = "de";
const t = i18n[lang];
---

<ContainerLayout
  title={`${t.about.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  ogImage={portrait.src}
  ogAlt="Portraet von Tim Adler"
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.about.title}</h1>
    <img class="portrait" src={portrait.src} width={portrait.width} height={portrait.height} alt="Portraet von Tim Adler" />
    <p class="lead">
      Seit mehr als 15 Jahren arbeite ich als Designer, Entwickler und Technik-Manager.
      Von den ersten Schritten als Junior-Programmierer bis zur Verantwortung als CTO
      habe ich in unterschiedlichen Rollen immer hands-on in der technischen
      Produktentwicklung gearbeitet.
    </p>
    <p>
      Ich entscheide nicht nur mit, ich packe auch in der Umsetzung an: vom Programmieren
      bis zum taeglichen Status-Meeting. In allen Rollen war ich Uebersetzer zwischen
      Geschaeftsanforderungen und technischen Rahmenbedingungen.
    </p>
    <ul class="claims">
      {t.home.roles.map((role) => (
        <li>{role}</li>
      ))}
    </ul>

  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .page > p,
  .lead {
    max-width: 66ch;
    margin: 0;
  }

  .lead {
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .claims {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2xs);
    font-weight: var(--font-weight-medium);
    max-width: 66ch;
  }

  .portrait {
    width: min(100%, 18rem);
    height: auto;
    border-radius: var(--radius-m);
    justify-self: start;

    @media (width >= 920px) {
      float: right;
      margin: 0 0 var(--space-l) var(--space-xl);
      width: min(40vw, 20rem);
    }
  }

</style>
