---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import WorkAccordionList from "../../components/WorkAccordionList.astro";
import { i18n } from "../../i18n";
import {
  openSourceEntries,
  projectEntries,
  publicationEntries,
} from "../../content/work";

const lang = "de";
const t = i18n[lang];
---

<ContainerLayout
  title={`${t.work.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.work.title}</h1>
    <p class="lead">Effizient großartige, digitale Produkte entwickeln</p>
    <p>
      Das Schöne an der digitalen Produktentwicklung ist: "Alles ist möglich, es ist nur
      eine Frage von Zeit und Geld." Das ist aber auch ihr Fluch. Denn es ermöglicht
      sowohl unzureichend kleine als auch überwältigend komplexe Lösungen.
    </p>
    <p>
      Deshalb starte ich bei jeder Produktentwicklung bei Business und Kunden und suche
      dann die effizienteste technische Lösung, auch mit geeigneten Drittanbieter-Werkzeugen.
    </p>

    <ContentSection title="Veröffentlichungen">
      <WorkAccordionList lang={lang} items={publicationEntries} />
    </ContentSection>

    <ContentSection title="Open Source">
      <WorkAccordionList lang={lang} items={openSourceEntries} />
    </ContentSection>

    <ContentSection title="Projekte">
      <WorkAccordionList lang={lang} items={projectEntries} />
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .kicker {
    margin: 0;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-10);
    font-size: var(--step--1);
  }

  .lead {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    max-width: 24ch;
    margin: 0;
  }

  .page > p:not(.kicker):not(.lead) {
    margin: 0;
    max-width: 66ch;
    line-height: var(--line-height-snug);
  }

  .page :global(.content-section) {
    padding-top: var(--space-xl);
  }

  .page :global(.content-section h2) {
    font-size: var(--step-2);
  }
</style>
