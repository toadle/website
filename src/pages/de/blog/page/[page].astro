---
import type { CollectionEntry } from "astro:content";
import BlogPaginatedPage from "../../../../layouts/BlogPaginatedPage.astro";
import { getBlogPaginatedPaths } from "../../../../lib/staticPaths";

export const getStaticPaths = () => getBlogPaginatedPaths("de");

type Props = {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
};

const { posts, currentPage, prevUrl, nextUrl } = Astro.props;
---
<BlogPaginatedPage
  lang="de"
  posts={posts}
  currentPage={currentPage}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
/>
