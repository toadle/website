---
import { getCollection } from "astro:content";
import ContainerLayout from "../../../../layouts/ContainerLayout.astro";
import FormattedDate from "../../../../components/FormattedDate.astro";
import { i18n } from "../../../../i18n";
import { isEntryInLocale } from "../../../../lib/contentLocale";
import { normalizeBlogSlug } from "../../../../lib/contentSlug";

const lang = "de";
const t = i18n[lang];

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const pageSize = 5;
  const posts = (await getCollection("blog"))
    .filter((post) => isEntryInLocale(post.id, "de", post.data.lang))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(posts, { pageSize }).filter(
    (entry: { params: { page: string } }) => entry.params.page !== "1"
  );
}

const { page } = Astro.props as { page: any };

const normalizePageUrl = (href: string | undefined) => {
  if (!href) {
    return undefined;
  }
  return href.endsWith("/page/1") ? "/de/blog" : href;
};
---

<ContainerLayout
  title={`${t.blog.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  ogImage="/og/default.png"
  ogAlt="Blog von Tim Adler"
  padTop
  padBottom
>
  <section class="page-wrap">
    <header class="intro">
      <h1>{t.blog.title}</h1>
      <p>{t.blog.lead}</p>
    </header>

    <ul class="posts">
      {page.data.map((post: any) => (
        <li>
          <a href={`/de/blog/${normalizeBlogSlug(post.id)}/`}>
            <h4 class="title">{post.data.title}</h4>
            <p class="date">
              <FormattedDate date={post.data.pubDate} locale="de-DE" />
            </p>
          </a>
        </li>
      ))}
    </ul>

    <nav class="pagination" aria-label="Blog pagination">
      {normalizePageUrl(page.url.prev) ? (
        <a href={normalizePageUrl(page.url.prev)}>← Vorherige Seite</a>
      ) : (
        <span />
      )}
      <span>Seite {page.currentPage}</span>
      {page.url.next ? <a href={page.url.next}>Nächste Seite →</a> : <span />}
    </nav>
  </section>
</ContainerLayout>

<style>
  .page-wrap {
    display: grid;
    gap: var(--space-xl);
  }

  .intro {
    display: grid;
    gap: var(--space-xs);
    max-width: 60ch;
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-s);
  }

  .posts a {
    text-decoration: none;
    display: grid;
    gap: var(--space-xs);
    padding-block: var(--space-xs);
    border-bottom: 1px solid var(--gray-4);
  }

  .posts li:last-child a {
    border-bottom: none;
  }

  .date {
    font-size: var(--step--1);
    color: var(--gray-10);
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    gap: var(--space-s);
    border-top: 1px solid var(--gray-4);
    padding-top: var(--space-s);
  }
</style>
