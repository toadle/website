---
import { type CollectionEntry, render } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";
import { getBlogStaticPaths } from "../../../lib/staticPaths";

type NavPost = { title: string; slug: string };

export const getStaticPaths = () => getBlogStaticPaths("de");

type Props = CollectionEntry<"blog"> & {
  lang: "de";
  prevPost?: NavPost;
  nextPost?: NavPost;
  translationHref?: string;
};

const post = Astro.props as Props;
const { Content } = await render(post);
---
<BlogPost
  {...post.data}
  lang={post.lang}
  prevPost={post.prevPost}
  nextPost={post.nextPost}
  translationHref={post.translationHref}
>
  <Content />
</BlogPost>
