---
import { getCollection } from "astro:content";
import ContainerLayout from "../../../layouts/ContainerLayout.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import { i18n } from "../../../i18n";
import { isEntryInLocale } from "../../../lib/contentLocale";
import { normalizeBlogSlug } from "../../../lib/contentSlug";
import { getSectionFeedLinks } from "../../../lib/rss";

const lang = "de";
const t = i18n[lang];
const PAGE_SIZE = 5;
const posts = (await getCollection("blog"))
  .filter((post) => isEntryInLocale(post.id, "de", post.data.lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const firstPagePosts = posts.slice(0, PAGE_SIZE);
const hasNextPage = posts.length > PAGE_SIZE;
---
<ContainerLayout
  title={`${t.blog.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  ogImage="/og/default.png"
  ogAlt="Blog von Tim Adler"
  feedLinks={getSectionFeedLinks(lang, "blog")}
  padTop
  padBottom
>
  <section class="page">
    <header class="intro">
      <h1>{t.blog.title}</h1>
      <p>{t.blog.lead}</p>
    </header>
    <ul class="posts">
      {firstPagePosts.map((post) => (
        <li>
          <a href={`/de/blog/${normalizeBlogSlug(post.id)}/`}>
            <h4 class="title">{post.data.title}</h4>
            <p class="date">
              <FormattedDate date={post.data.pubDate} locale="de-DE" />
            </p>
          </a>
        </li>
      ))}
    </ul>
    {
      hasNextPage && (
        <nav class="pagination" aria-label="Blog pagination">
          <span>Seite 1</span>
          <a href="/de/blog/page/2">Nächste Seite →</a>
        </nav>
      )
    }
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-xl);
  }

  .intro {
    display: grid;
    gap: var(--space-xs);
    max-width: 60ch;
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-s);
  }

  .posts a {
    text-decoration: none;
    display: grid;
    gap: var(--space-xs);
    padding-block: var(--space-xs);
    border-bottom: 1px solid var(--gray-4);
  }

  .posts li:last-child a {
    border-bottom: none;
  }

  .date {
    font-size: var(--step--1);
    color: var(--gray-10);
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    gap: var(--space-s);
    border-top: 1px solid var(--gray-4);
    padding-top: var(--space-s);
  }
</style>
