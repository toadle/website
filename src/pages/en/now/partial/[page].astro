---
import { type CollectionEntry, render } from "astro:content";
import NowTimelineItem from "../../../../components/NowTimelineItem.astro";
import { i18n } from "../../../../i18n";
import { normalizeNowSlug } from "../../../../lib/contentSlug";
import { formatNowDate } from "../../../../lib/dates";
import { getNowPartialPaths } from "../../../../lib/staticPaths";

export const getStaticPaths = () => getNowPartialPaths("en");

const lang = "en";
const t = i18n[lang];

type Props = { pageEntries: CollectionEntry<"now">[] };
const { pageEntries } = Astro.props;

const entries = await Promise.all(
  pageEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<ol>
  {entries.map(({ entry, Content }) => (
    <NowTimelineItem
      entry={entry}
      Content={Content}
      dateText={formatNowDate(entry.data.date, lang)}
      ratingLabel={t.now.ratingLabel}
      dateHref={`/${lang}/now/${normalizeNowSlug(entry.id)}/`}
    />
  ))}
</ol>
