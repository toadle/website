---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import WorkAccordionList from "../../components/WorkAccordionList.astro";
import { i18n } from "../../i18n";
import { projectEntries } from "../../content/work";

const lang = "en";
const t = i18n[lang];
---

<ContainerLayout
  title={`Services · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>Services</h1>
    <p class="lead">Ship digital products with clarity and speed.</p>
    <p>
      I help teams turn product ideas into reliable digital outcomes through
      focused execution, pragmatic technology choices, and a delivery setup that
      works under real deadlines and constraints.
    </p>
    <p>
      Whether you are launching, stabilizing, or untangling a critical phase,
      I connect product and engineering, reduce complexity, and create visible
      progress quickly.
    </p>

    <ContentSection title="Selected client projects">
      <WorkAccordionList lang={lang} items={projectEntries} />
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .lead {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    max-width: 24ch;
    margin: 0;
  }

  .page > p:not(.lead) {
    margin: 0;
    max-width: 66ch;
    line-height: var(--line-height-snug);
  }

  .page :global(.content-section) {
    padding-top: var(--space-xl);
  }

  .page :global(.content-section h2) {
    font-size: var(--step-2);
  }
</style>
