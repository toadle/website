---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import { i18n } from "../../i18n";
import portrait from "../../assets/legacy/ich.png";

const lang = "en";
const t = i18n[lang];

const capabilitySections = [
  {
    title: "Frontend",
    items: [
      "HTML",
      "CSS",
      "SASS",
      "JavaScript",
      "React",
      "React Native",
      "Redux",
      "SwiftUI",
      "JAMStack",
      "Microformats",
      "jQuery",
      "Bootstrap",
    ],
  },
  {
    title: "Backend",
    items: [
      "Ruby On Rails",
      "Ruby",
      "Golang",
      "Swift",
      "GraphQL",
      "JSONAPI",
      "Node.js",
      "Python",
      "Django",
      "Docker",
      "Amazon Web Services",
    ],
  },
  {
    title: "Databases",
    items: ["MySQL", "Postgres", "Redis", "Oracle", "ElasticSearch"],
  },
  {
    title: "Third Parties",
    items: [
      "Github",
      "Stripe",
      "CircleCI",
      "Github Actions",
      "SalesForce",
      "Contentful",
      "GSuite",
      "AWS",
      "Teachable",
      "Recurly",
      "RevenueCat",
      "Facebook Ads",
      "Google Ads",
      "AppStore",
      "Zapier",
      "Mailchimp",
      "Mandrill",
      "Braze",
    ],
  },
  {
    title: "Methods",
    items: [
      "Git",
      "TDD",
      "SCRUM",
      "Design Thinking",
      "Rapid Prototyping",
      "Lean Startup",
      "Business Model Canvas",
    ],
  },
];

const career = [
  {
    role: "CTO",
    years: "2020 - today",
    organization: "Chefkoch",
    url: "https://www.chefkoch.de",
  },
  {
    role: "Managing Director",
    years: "2019 - 2020",
    organization: "Innovation Lab",
    url: "https://greenhouse.media",
  },
  {
    role: "Head of Technology",
    years: "2017 - 2019",
    organization: "Innovation Lab",
    url: "https://greenhouse.media",
  },
  {
    role: "Head of Development",
    years: "2013 - 2017",
    organization: "Startup Incubator / Company Builder",
    url: "https://www.hanseventures.com",
  },
  {
    role: "Project Manager",
    years: "2011 - 2012",
    organization: "Operations / Digital",
    url: "https://www.guj.de",
  },
  {
    role: "Product Manager",
    years: "2010",
    organization: "iPad Version of a News Magazine",
    url: "https://www.stern.de",
  },
  {
    role: "Management Trainee",
    years: "2009",
    organization: "International Publisher",
    url: "https://www.guj.de",
  },
  {
    role: "Web Developer",
    years: "2006 - 2008",
    organization: "Advertising Agency",
  },
  {
    role: "Designer, Developer",
    years: "2006 - 2008",
    organization: "Self employed",
  },
  {
    role: "Java Developer",
    years: "2004",
    organization: "Direct Marketing Company",
    url: "https://www.az-direct.com",
  },
];
---

<ContainerLayout
  title={`${t.about.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.about.title}</h1>
    <img class="portrait" src={portrait.src} width={portrait.width} height={portrait.height} alt="Portrait of Tim Adler" />
    <p class="lead">
      For more than 15 years I have been working as a designer, developer and
      technical manager. From my first steps as a junior programmer to leading
      as CTO, I have contributed to technical product development in hands-on roles.
    </p>
    <p>
      I like not only to help decide, but also to execute: from programming to the
      daily status meeting. Across all roles, I have been a translator between
      business requirements and technical constraints.
    </p>

    <ContentSection title="What I do" kicker="Capabilities">
      <div class="capability-grid">
        {capabilitySections.map((section) => (
          <section class="capability-section">
            <h3>{section.title}</h3>
            <ul class="capability-tags">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </ContentSection>

    <ContentSection title="Experience" kicker="Where I came from">
      <ol class="timeline">
        {career.map((entry) => (
          <li>
            <article>
              <header>
                <h3>{entry.role}</h3>
                <span>{entry.years}</span>
              </header>
              {
                entry.url ? (
                  <a href={entry.url} target="_blank" rel="noopener noreferrer">
                    {entry.organization}
                  </a>
                ) : (
                  <p>{entry.organization}</p>
                )
              }
            </article>
          </li>
        ))}
      </ol>
    </ContentSection>

    <ContentSection title="Education">
      <ul class="education">
        <li>
          <strong>Diploma in Media Studies</strong>
          <span>2004 - 2008</span>
          <p>University Paderborn</p>
        </li>
        <li>
          <strong>Certified SCRUM Master</strong>
          <span>2015</span>
          <p>IT agile</p>
        </li>
        <li>
          <strong>IT Specialist</strong>
          <span>2001 - 2004</span>
          <p>International Media Corporation</p>
        </li>
      </ul>
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .page > p,
  .lead {
    max-width: 66ch;
    margin: 0;
  }

  .lead {
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .portrait {
    width: min(100%, 18rem);
    height: auto;
    border-radius: var(--radius-m);
    justify-self: start;

    @media (width >= 920px) {
      float: right;
      margin: 0 0 var(--space-l) var(--space-xl);
      width: min(40vw, 20rem);
    }
  }

  .page :global(.content-section) {
    border-top: 1px solid var(--gray-5);
    padding-top: var(--space-xl);
  }

  .page :global(.content-section h2) {
    font-size: var(--step-2);
    letter-spacing: var(--letter-spacing-condensed);
  }

  .capability-grid {
    display: grid;
    gap: var(--space-l);

    @media (width >= 760px) {
      gap: var(--space-m);
    }
  }

  .capability-section {
    display: grid;
    gap: var(--space-s);

    @media (width >= 760px) {
      grid-template-columns: 10rem 1fr;
      align-items: start;
      column-gap: var(--space-l);
    }
  }

  .capability-section h3 {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--step--1);
    color: var(--gray-10);
  }

  .capability-tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .capability-tags li {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.18rem 0.45rem;
    border-radius: var(--radius-xs);
    border: 1px solid var(--gray-6);
    background: var(--gray-3);
    font-size: var(--step--1);
    line-height: var(--line-height-single);
    white-space: nowrap;
  }

  .capability-tags li::before {
    content: "#";
    color: var(--gray-10);
  }

  .timeline {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-m);
  }

  .timeline article {
    border-bottom: 1px solid var(--gray-5);
    padding-bottom: var(--space-m);
  }

  .timeline li:last-child article {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .timeline header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .timeline h3 {
    margin: 0;
  }

  .timeline a,
  .timeline p {
    margin: var(--space-2xs) 0 0;
  }

  .timeline p {
    color: var(--gray-11);
  }

  .education {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-m);
  }

  .education li {
    display: grid;
    gap: var(--space-2xs);
    border-bottom: 1px solid var(--gray-5);
    padding-bottom: var(--space-m);
  }

  .education li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .education p,
  .education span,
  .timeline span {
    color: var(--gray-10);
  }
</style>
