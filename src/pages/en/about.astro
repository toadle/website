---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import { i18n } from "../../i18n";
import portrait from "../../assets/legacy/ich.png";

const lang = "en";
const t = i18n[lang];
---

<ContainerLayout
  title={`${t.about.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.about.title}</h1>
    <img class="portrait" src={portrait.src} width={portrait.width} height={portrait.height} alt="Portrait of Tim Adler" />
    <p class="lead">
      For more than 15 years I have been working as a designer, developer and
      technical manager. From my first steps as a junior programmer to leading
      as CTO, I have contributed to technical product development in hands-on roles.
    </p>
    <p>
      I like not only to help decide, but also to execute: from programming to the
      daily status meeting. Across all roles, I have been a translator between
      business requirements and technical constraints.
    </p>

  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .page > p,
  .lead {
    max-width: 66ch;
    margin: 0;
  }

  .lead {
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .portrait {
    width: min(100%, 18rem);
    height: auto;
    border-radius: var(--radius-m);
    justify-self: start;

    @media (width >= 920px) {
      float: right;
      margin: 0 0 var(--space-l) var(--space-xl);
      width: min(40vw, 20rem);
    }
  }

</style>
