---
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import ContentSection from "../../components/ContentSection.astro";
import WorkAccordionList from "../../components/WorkAccordionList.astro";
import { i18n } from "../../i18n";
import {
  openSourceEntries,
  projectEntries,
  publicationEntries,
} from "../../content/work";

const lang = "en";
const t = i18n[lang];
---

<ContainerLayout
  title={`${t.work.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <h1>{t.work.title}</h1>
    <p class="lead">Build great digital products efficiently</p>
    <p>
      The beauty of digital product development is: "Anything is possible, it is
      just a matter of time and money." That is also its curse. It enables both
      insufficiently small and overwhelmingly complex solutions.
    </p>
    <p>
      That is why I start with business and customer needs and then recommend the
      most efficient technical solution, often by selecting strong third-party tools.
    </p>

    <ContentSection title="Publications">
      <WorkAccordionList lang={lang} items={publicationEntries} />
    </ContentSection>

    <ContentSection title="Open Source">
      <WorkAccordionList lang={lang} items={openSourceEntries} />
    </ContentSection>

    <ContentSection title="Projects">
      <WorkAccordionList lang={lang} items={projectEntries} />
    </ContentSection>
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-2xl);
    max-width: 76ch;
    margin-inline: auto;
  }

  h1 {
    margin: 0;
  }

  .kicker {
    margin: 0;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-10);
    font-size: var(--step--1);
  }

  .lead {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    max-width: 24ch;
    margin: 0;
  }

  .page > p:not(.kicker):not(.lead) {
    margin: 0;
    max-width: 66ch;
    line-height: var(--line-height-snug);
  }

  .page :global(.content-section) {
    padding-top: var(--space-xl);
  }

  .page :global(.content-section h2) {
    font-size: var(--step-2);
  }
</style>
