---
import { getCollection, render } from "astro:content";
import ContainerLayout from "../../layouts/ContainerLayout.astro";
import { i18n } from "../../i18n";
import { isEntryInLocale } from "../../lib/contentLocale";
import { sortNowEntries } from "../../lib/nowImport/sortNowEntries";
import NowRating from "../../components/NowRating.astro";
import Richlink from "../../components/Richlink.astro";

const lang = "en";
const t = i18n[lang];
const PAGE_SIZE = 10;

const rawEntries = sortNowEntries(
  (await getCollection("now")).filter((entry) =>
    isEntryInLocale(entry.id, lang, entry.data.lang)
  )
);

const entries = await Promise.all(
  rawEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const toEmbedUrl = (url: string) => {
  try {
    const parsed = new URL(url);
    if (parsed.hostname.includes("youtube.com")) {
      const id = parsed.searchParams.get("v");
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
    if (parsed.hostname.includes("youtu.be")) {
      const id = parsed.pathname.replace("/", "");
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
  } catch (err) {
    return "";
  }
  return "";
};

const formatNowDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
---

<ContainerLayout
  title={`${t.now.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  padTop
  padBottom
>
  <section class="page">
    <header class="intro">
      <h1>{t.now.title}</h1>
      <p class="lead">{t.now.lead}</p>
    </header>

    <ol id="now-timeline" class="timeline" data-load-more-list data-page-size={PAGE_SIZE}>
      {entries.map(({ entry, Content }, index) => (
        <li data-load-more-item hidden={index >= PAGE_SIZE}>
          <time datetime={entry.data.date.toISOString()}>{formatNowDate(entry.data.date)}</time>
          {entry.data.rating && <NowRating rating={entry.data.rating} label="My rating" />}
          {entry.data.quote && <blockquote>{entry.data.quote}</blockquote>}
          {entry.body?.trim() && (
            <div class="body">
              <Content />
            </div>
          )}
          {entry.data.reviewText && <p class="opinion">{entry.data.reviewText}</p>}
          {entry.data.opinion && <p class="opinion">{entry.data.opinion}</p>}
          {entry.data.richlink && <Richlink link={entry.data.richlink} />}
          {entry.data.youtube && (
            <div class="embed">
              <iframe
                src={toEmbedUrl(entry.data.youtube)}
                title="YouTube video"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          )}
          {entry.data.image && (
            <figure>
              <img
                src={entry.data.image.src}
                alt={entry.data.image.alt}
                loading="lazy"
              />
            </figure>
          )}
        </li>
      ))}
    </ol>

    {entries.length > PAGE_SIZE && (
      <div class="load-more-wrap">
        <button
          type="button"
          class="load-more"
          data-load-more-button
          aria-controls="now-timeline"
        >
          Load more
        </button>
      </div>
    )}
  </section>
</ContainerLayout>

<script>
  const list = document.querySelector("[data-load-more-list]");
  const button = document.querySelector("[data-load-more-button]");

  if (list instanceof HTMLElement && button instanceof HTMLButtonElement) {
    const items = Array.from(list.querySelectorAll("[data-load-more-item]"));
    const pageSizeRaw = Number.parseInt(list.dataset.pageSize ?? "10", 10);
    const pageSize = Number.isFinite(pageSizeRaw) && pageSizeRaw > 0 ? pageSizeRaw : 10;
    let visibleCount = Math.min(pageSize, items.length);

    const update = () => {
      items.forEach((item, index) => {
        item.hidden = index >= visibleCount;
      });

      button.hidden = visibleCount >= items.length;
    };

    button.addEventListener("click", () => {
      visibleCount = Math.min(visibleCount + pageSize, items.length);
      update();
    });

    update();
  }
</script>

<style>
  :global(body) {
    background-color: var(--gray-1);
    color: var(--gray-12);
  }

  :global(a) {
    color: inherit;
    text-decoration-color: var(--gray-7);
  }

  .page {
    display: grid;
    gap: var(--space-2xl);
  }

  .lead {
    font-size: var(--step-1);
    max-width: 60ch;
    color: var(--gray-10);
  }

  .intro {
    display: grid;
    gap: var(--space-xs);
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-l);
    position: relative;
  }

  .timeline::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 10px;
    width: 2px;
    background: var(--gray-4);
    border-radius: 999px;
  }

  .timeline li {
    position: relative;
    padding-left: var(--space-2xl);
    display: grid;
    gap: var(--space-xs);
  }

  .timeline li[hidden] {
    display: none;
  }

  .timeline li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gray-7);
    border: 2px solid var(--gray-2);
    box-shadow: 0 0 0 2px var(--gray-1);
  }

  .timeline time {
    font-size: var(--step--1);
    color: var(--gray-10);
    letter-spacing: 0.02em;
  }

  .timeline p {
    margin: 0;
    font-size: var(--step-0);
    max-width: 70ch;
  }

  .timeline .body :global(p) {
    margin: 0;
    font-size: var(--step-0);
    max-width: 70ch;
  }

  .timeline blockquote {
    margin: 0;
    padding-left: var(--space-m);
    border-left: 2px solid var(--gray-6);
    color: var(--gray-12);
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .timeline .opinion {
    color: var(--gray-10);
    font-style: italic;
  }

  .timeline figure {
    margin: 0;
  }

  .timeline img {
    width: 100%;
    border-radius: var(--radius-m);
    border: 1px solid var(--gray-4);
    display: block;
  }

  .embed {
    position: relative;
    padding-top: 56.25%;
    border-radius: var(--radius-m);
    border: 1px solid var(--gray-4);
    overflow: hidden;
    background: var(--gray-2);
  }

  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .load-more-wrap {
    display: flex;
    justify-content: center;
  }

  .load-more {
    border: 1px solid var(--gray-6);
    background: var(--gray-2);
    color: var(--gray-12);
    border-radius: 999px;
    padding: 0.55rem 1rem;
    font-size: var(--step--1);
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background-color 160ms ease, border-color 160ms ease;
  }

  .load-more:hover {
    background: var(--gray-3);
    border-color: var(--gray-7);
  }
</style>
