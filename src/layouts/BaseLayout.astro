---
import "../styles/base.css";
import "../styles/reset.css";
import "../styles/theme.css";
import { Font } from "astro:assets";

import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  description: string;
  lang?: string;
  ogImage?: string;
  ogAlt?: string;
  ogType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  feedLinks?: { title: string; href: string }[];
}

const {
  title,
  description,
  lang = "de",
  ogImage,
  ogAlt,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  feedLinks = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = Astro.url.pathname === "/" ? title : `${title}`;
const ogLocale = lang === "en" ? "en_US" : "de_DE";
const defaultOgImagePath = "/og/default.png";
const defaultOgAltByLocale = {
  de: "Tim Adler baut Technik, die funktioniert und echten Wert schafft.",
  en: "Tim Adler builds practical technology that creates real value.",
};
const resolvedOgImage = new URL(
  ogImage ?? defaultOgImagePath,
  Astro.site
).toString();
const resolvedOgAlt =
  ogAlt ??
  (lang === "en" ? defaultOgAltByLocale.en : defaultOgAltByLocale.de);
---

<!doctype html>
<html lang={lang} transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#FCFCFC" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#111111"
    />
    <link rel="stylesheet" href="https://use.typekit.net/ytg3gfn.css" />
    <link rel="icon" href="/favicon.png?v=5" type="image/png" />
    <link rel="canonical" href={canonicalURL} />
    {feedLinks.map((feedLink) => (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={feedLink.title}
        href={new URL(feedLink.href, Astro.site)}
      />
    ))}
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Tim Adler" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content={resolvedOgAlt} />
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
