---
import { getCollection } from "astro:content";
import ContainerLayout from "./ContainerLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { i18n, type Locale } from "../i18n";
import { isEntryInLocale } from "../lib/contentLocale";
import { normalizeBlogSlug } from "../lib/contentSlug";
import { renderInlineMarkdown } from "../lib/renderInlineMarkdown";
import { getSectionFeedLinks } from "../lib/rss";
import { DATE_LOCALE } from "../lib/dates";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = i18n[lang];
const PAGE_SIZE = 5;

const posts = (await getCollection("blog"))
  .filter((post) => isEntryInLocale(post.id, lang, post.data.lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const firstPagePosts = posts.slice(0, PAGE_SIZE);
const hasNextPage = posts.length > PAGE_SIZE;
---

<ContainerLayout
  title={`${t.blog.title} · ${t.siteTitle}`}
  description={t.siteDescription}
  lang={lang}
  ogImage="/og/default.png"
  ogAlt={t.blog.ogAlt}
  feedLinks={getSectionFeedLinks(lang, "blog")}
  padTop
  padBottom
>
  <section class="page">
    <header class="intro">
      <h1>{t.blog.title}</h1>
      <p>{t.blog.lead}</p>
    </header>
    <ul class="posts">
      {firstPagePosts.map((post) => (
        <li>
          <a href={`/${lang}/blog/${normalizeBlogSlug(post.id)}/`}>
            <h4 class="title" set:html={renderInlineMarkdown(post.data.title)} />
            <p class="date">
              <FormattedDate date={post.data.pubDate} locale={DATE_LOCALE[lang]} />
            </p>
          </a>
        </li>
      ))}
    </ul>
    {hasNextPage && (
      <nav class="pagination" aria-label="Blog pagination">
        <span>{t.blog.pagination.page} 1</span>
        <a href={`/${lang}/blog/page/2`}>{t.blog.pagination.next}</a>
      </nav>
    )}
  </section>
</ContainerLayout>

<style>
  .page {
    display: grid;
    gap: var(--space-xl);
  }

  .intro {
    display: grid;
    gap: var(--space-xs);
    max-width: 60ch;
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-s);
  }

  .posts a {
    text-decoration: none;
    display: grid;
    gap: var(--space-xs);
    padding-block: var(--space-xs);
    border-bottom: 1px solid var(--gray-4);
  }

  .posts li:last-child a {
    border-bottom: none;
  }

  .date {
    font-size: var(--step--1);
    color: var(--gray-10);
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    gap: var(--space-s);
    border-top: 1px solid var(--gray-4);
    padding-top: var(--space-s);
  }
</style>
