---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ContainerLayout from './ContainerLayout.astro';
import Center from '../components/Center.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { lang?: string };

const { title, description, pubDate, updatedDate, heroImage, lang = "de" } =
  Astro.props;

---
<BaseLayout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <main class="main">
    <Center>
      <article class="article">
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate
                date={pubDate}
                locale={lang === "en" ? "en-US" : "de-DE"}
              />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    {lang === "en" ? "Last updated on" : "Zuletzt aktualisiert am"}{" "}
                    <FormattedDate
                      date={updatedDate}
                      locale={lang === "en" ? "en-US" : "de-DE"}
                    />
                  </div>
                )
              }
            </div>
            <h1>{title}</h1>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </Center>
  </main>
  <Footer />
</BaseLayout>

<style>
  .main {
    padding-block: var(--space-3xl);
  }

  .article {
    display: grid;
    gap: var(--space-l);
    width: 100%;
  }

  .hero-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .prose {
    display: grid;
    gap: var(--space-l);
    max-width: 72ch;
  }

  .title {
    display: grid;
    gap: var(--space-xs);
  }

  .date {
    color: var(--gray-10);
    font-size: var(--step--1);
  }

  hr {
    border: none;
    border-top: 1px solid var(--gray-4);
  }
</style>
