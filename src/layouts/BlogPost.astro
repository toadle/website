---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Center from '../components/Center.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header/Header.astro';
import ArticleNav from '../components/ArticleNav.astro';
import { i18n, type Locale } from '../i18n';
import { renderInlineMarkdown } from '../lib/renderInlineMarkdown';

type NavPost = { title: string; slug: string };

type Props = CollectionEntry<'blog'>['data'] & {
  lang?: Locale;
  prevPost?: NavPost;
  nextPost?: NavPost;
  translationHref?: string;
};

const {
  title,
  subtitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  lang = "de",
  prevPost,
  nextPost,
  translationHref,
} = Astro.props;

const t = i18n[lang].blog.articleNav;
const normalizeHref = (href: string) => (href.startsWith("/") ? href : `/${href}`);
const otherLang: Locale = lang === "de" ? "en" : "de";
const blogLanguageSwitchHref = translationHref
  ? normalizeHref(translationHref)
  : `/${otherLang}/blog`;
const articlePublishedTime = pubDate.toISOString();
const articleModifiedTime = updatedDate?.toISOString();
const articleOgAlt =
  lang === "en"
    ? `${title} - article by Tim Adler`
    : `${title} - Artikel von Tim Adler`;
const titleHtml = renderInlineMarkdown(title);

---
<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogType="article"
  ogImage={heroImage?.src}
  ogAlt={articleOgAlt}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
  articleAuthor="Tim Adler"
>
  <Header lang={lang} languageSwitchHref={blogLanguageSwitchHref} />
  <main class="main">
    <Center>
      <article class="article">
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class="prose">
          <div class="title">
            <div class="meta-row">
              <div class="date">
                <FormattedDate
                  date={pubDate}
                  locale={lang === "en" ? "en-US" : "de-DE"}
                />
                {
                  updatedDate && (
                    <div class="last-updated-on">
                      {lang === "en" ? "Last updated on" : "Zuletzt aktualisiert am"}{" "}
                      <FormattedDate
                        date={updatedDate}
                        locale={lang === "en" ? "en-US" : "de-DE"}
                      />
                    </div>
                  )
                }
              </div>
              {
                translationHref && (
                  <a class="translation-link" href={normalizeHref(translationHref)}>
                    {t.readIn}
                  </a>
                )
              }
            </div>
            <h1 set:html={titleHtml} />
            {subtitle && <p class="subtitle">{subtitle}</p>}
          </div>
          <slot />
          <ArticleNav
            lang={lang === "en" ? "en" : "de"}
            prev={prevPost}
            next={nextPost}
          />
        </div>
      </article>
    </Center>
  </main>
  <Footer />
</BaseLayout>

<style>
  .main {
    padding-block: var(--space-3xl);
    width: 100%;
  }

  .article {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-l);
    width: 100%;
  }

  .hero-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-s);
  }

  .prose {
    width: 100%;
    max-width: none;
    margin-inline: auto;
  }

  .prose > :global(* + *) {
    margin-top: var(--space-l);
  }

  .prose > :global(h5 + p),
  .prose > :global(h5 + ul),
  .prose > :global(h5 + ol),
  .prose > :global(h5 + blockquote),
  .prose > :global(h5 + pre) {
    margin-top: var(--space-xs);
  }

  .title {
    display: grid;
    gap: var(--space-xs);
  }

  .subtitle {
    font-size: var(--step-3);
    line-height: var(--line-height-tight);
    max-width: 30ch;
    margin: 0;
    color: var(--gray-12);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-s);
  }

  .date {
    color: var(--gray-10);
    font-size: var(--step--1);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-s);
  }

  .translation-link {
    color: var(--gray-11);
    font-size: var(--step--1);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .prose
    > :global(
      p:not(:has(img, picture, video, iframe, figure))
        + p:not(:has(img, picture, video, iframe, figure))
    ) {
    margin-top: 0;
    text-indent: 1.5em;
  }

  .prose :global(pre) {
    padding: var(--space-m) var(--space-l);
    border-radius: var(--radius-s);
    overflow-x: auto;
    line-height: var(--line-height-snug);
  }

  .prose :global(pre code) {
    display: block;
    line-height: inherit;
  }

  .prose :global(img) {
    border-radius: var(--radius-s);
  }

  .prose :global(picture img) {
    width: 100%;
    height: auto;
    display: block;
  }

  hr {
    border: none;
    border-top: 1px solid var(--gray-4);
  }
</style>
