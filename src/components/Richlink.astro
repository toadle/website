---
import { resolveRichlinkDetails } from "../lib/richlinkCover";

type Richlink = {
  title?: string;
  show?: string;
  url: string;
  kind?: "movie" | "recommendation";
  backlink?: boolean;
  description?: string;
  cover?: {
    src: string;
    alt: string;
  };
};

interface Props {
  link: Richlink;
  variant?: "now" | "blog";
}

const { link, variant = "now" } = Astro.props;
const { title, description, cover } = await resolveRichlinkDetails(link);
const hasCover = Boolean(cover);
const pageLocale = Astro.url.pathname.startsWith("/en/") ? "en" : "de";
const showConnector = pageLocale === "en" ? "from" : "aus";
---

{variant === "blog" ? (
  <a
    class:list={[
      "richlink-wrap",
      "richlink-wrap--blog",
      hasCover && "richlink-wrap--has-cover",
      "richlink-card-link",
    ]}
    href={link.url}
    rel="noopener noreferrer"
    target="_blank"
  >
    {cover && (
      <div class="richlink-cover" data-auto-cover>
        <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" />
      </div>
    )}
    <div class="richlink-content">
      <p class="richlink">
        <span class="richlink__title">{title}</span>
        {link.show && <span class="richlink__show">{showConnector} {link.show}</span>}
        {link.backlink && <span class="richlink__meta">IMDb</span>}
      </p>
      {description && <p class="richlink__description">{description}</p>}
    </div>
  </a>
) : (
  <div class:list={["richlink-wrap", "richlink-wrap--now", hasCover && "richlink-wrap--has-cover"]}>
    {cover && (
      <a class="richlink-cover" data-auto-cover href={link.url} rel="noopener noreferrer" target="_blank">
        <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" />
      </a>
    )}
    <div class="richlink-content">
      <p class="richlink">
        <a href={link.url} rel="noopener noreferrer" target="_blank">{title}</a>
        {link.show && <span class="richlink__show">{showConnector} {link.show}</span>}
        {link.backlink && <span class="richlink__meta">IMDb</span>}
      </p>
      {description && <p class="richlink__description">{description}</p>}
    </div>
  </div>
)}

<script is:inline>
  (() => {
    const classifyRichlinkCover = (cover) => {
      const image = cover.querySelector("img");

      if (!image) {
        return;
      }

      const update = () => {
        const width = image.naturalWidth;
        const height = image.naturalHeight;

        if (!width || !height) {
          return;
        }

        const ratio = width / height;
        cover.classList.remove("is-poster", "is-square", "is-landscape");

        if (ratio > 1.2) {
          cover.classList.add("is-landscape");
        } else if (ratio >= 0.85) {
          cover.classList.add("is-square");
        } else {
          cover.classList.add("is-poster");
        }
      };

      if (image.complete) {
        update();
        return;
      }

      image.addEventListener("load", update, { once: true });
    };

    const initRichlinkCovers = () => {
      document
        .querySelectorAll(".richlink-cover[data-auto-cover]")
        .forEach((cover) => classifyRichlinkCover(cover));
    };

    initRichlinkCovers();
    document.addEventListener("astro:after-swap", initRichlinkCovers);
  })();
</script>

<style>
  .richlink-wrap {
    display: grid;
    gap: var(--space-2xs);
    align-content: start;
  }

  .richlink-content {
    display: grid;
    gap: var(--space-2xs);
    align-content: start;
  }

  .richlink-cover {
    display: inline-flex;
    width: clamp(5.5rem, 24vw, 8rem);
    aspect-ratio: 2 / 3;
    border-radius: var(--radius-s);
    overflow: hidden;
    border: 1px solid var(--gray-5);
    background: var(--gray-2);
  }

  .richlink-cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .richlink-cover.is-square {
    aspect-ratio: 1 / 1;
  }

  .richlink-cover.is-square img {
    object-fit: contain;
  }

  .richlink-cover.is-landscape {
    aspect-ratio: 16 / 9;
    width: min(100%, clamp(8rem, 40vw, 14rem));
  }

  .richlink-cover.is-landscape img {
    object-fit: contain;
  }

  .richlink {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--step-0);
  }

  .richlink a {
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .richlink__meta {
    font-size: var(--step--1);
    color: var(--gray-10);
  }

  .richlink__show {
    color: var(--gray-11);
  }

  .richlink__description {
    margin: 0;
    color: var(--gray-10);
    font-size: var(--step--1);
  }

  .richlink-wrap--blog {
    border: 1px solid var(--gray-5);
    border-radius: var(--radius-m);
    background: linear-gradient(180deg, var(--gray-2), var(--gray-3));
    padding: var(--space-s);
    gap: var(--space-s);
  }

  .richlink-wrap--blog .richlink {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    row-gap: var(--space-2xs);
  }

  .richlink-wrap--blog .richlink a {
    font-weight: var(--font-weight-medium);
    text-decoration-thickness: 1.5px;
  }

  .richlink-card-link {
    color: inherit;
    text-decoration: none;
    transition: border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .richlink-card-link:hover {
    border-color: var(--gray-6);
    background: linear-gradient(180deg, var(--gray-3), var(--gray-4));
  }

  .richlink-card-link:focus-visible {
    outline: 2px solid var(--blue-8);
    outline-offset: 2px;
  }

  .richlink__title {
    font-weight: var(--font-weight-medium);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1.5px;
  }

  .richlink-wrap--blog .richlink__meta {
    border: 1px solid var(--gray-6);
    border-radius: var(--radius-full);
    background: var(--gray-4);
    padding-inline: 0.5em;
    line-height: 1.5;
  }

  .richlink-wrap--blog .richlink__description {
    color: var(--gray-11);
    line-height: var(--line-height-snug);
  }

  .richlink-wrap--blog .richlink-cover {
    border-radius: var(--radius-m);
    border-color: var(--gray-6);
    box-shadow: var(--shadow-s);
  }

  @media (min-width: 42rem) {
    .richlink-wrap--blog.richlink-wrap--has-cover {
      grid-template-columns: minmax(0, clamp(5.5rem, 18vw, 8rem)) 1fr;
      align-items: start;
    }

    .richlink-wrap--blog.richlink-wrap--has-cover .richlink-cover {
      width: 100%;
    }
  }
</style>
