---
interface LocalizedText {
  de: string;
  en: string;
}

interface Project {
  id: string;
  title: LocalizedText;
  description: LocalizedText;
  url: string;
  linkText?: string;
  year?: number;
  subtitle?: LocalizedText;
  technologies?: string[];
}

interface Props {
  lang: "de" | "en";
  items: Project[];
}

const { lang, items } = Astro.props;
---

<ul class="project-list">
  {items.map((item) => (
    <li>
      <article>
        <h3>{item.title[lang]}</h3>
        {item.subtitle && <p class="subtitle">{item.subtitle[lang]}</p>}
        <p>{item.description[lang]}</p>
        <p class="meta">
          {item.year && <span>{item.year}</span>}
          <a href={item.url} target="_blank" rel="noopener noreferrer">
            {item.linkText ?? item.url}
          </a>
        </p>
        {item.technologies && item.technologies.length > 0 && (
          <ul class="tags">
            {item.technologies.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        )}
      </article>
    </li>
  ))}
</ul>

<style>
  .project-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-l);
  }

  h3 {
    margin-block: 0 0.3rem;
  }

  .subtitle {
    margin: 0;
    color: var(--color-text-muted);
    font-weight: var(--font-weight-medium);
  }

  .meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }

  .meta a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .tags {
    margin: var(--space-s) 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tags li {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.18rem 0.45rem;
    border-radius: var(--radius-xs);
    border: 1px solid var(--gray-6);
    background: var(--gray-3);
    font-size: var(--step--1);
    line-height: var(--line-height-single);
    white-space: nowrap;
  }

  .tags li::before {
    content: "#";
    color: var(--gray-10);
  }
</style>
