---
import { i18n, type Locale } from "../i18n";
import Center from "./Center.astro";

const today = new Date();
const currentPath = Astro.url.pathname;
const firstSegment = currentPath.split("/").filter(Boolean)[0];
const lang: Locale =
  firstSegment === "en" || firstSegment === "de" ? firstSegment : "de";
const t = i18n[lang];

const leftLinks = [
  { label: "GitHub", href: "https://github.com/toadle" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/tim-adler-12ba11188/" },
  { label: "Mastodon", href: "https://mastodon.social/@toadle" },
];

const rightLinks = [
  { label: "Instagram", href: "https://www.instagram.com/t.o.adler/" },
  { label: "Blog RSS", href: `/${lang}/blog/rss.xml` },
  { label: "Now RSS", href: `/${lang}/now/rss.xml` },
  { label: "Email", href: "mailto:hello@toadle.me" },
];
---

<footer class="site-footer">
  <Center>
    <div class="inner">
    <div class="link-columns">
      <ul>
        {leftLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <ul>
        {rightLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <section class="mission">
      <p>{t.home.intro}</p>
      <small>&copy; {today.getFullYear()} Tim Adler</small>
    </section>
  </Center>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--gray-4);
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) 0;
    width: 100%;
  }

  .inner {
    display: grid;
    gap: var(--space-xl);

    @media (width >= 900px) {
      grid-template-columns: 1fr 1.3fr auto;
      align-items: start;
    }
  }

  .link-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s) var(--space-l);
  }

  .link-columns ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-xs);
  }

  .link-columns a {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .mission {
    display: grid;
    gap: var(--space-s);
    max-width: 48ch;
  }

  .mission h2 {
    font-size: var(--step-3);
  }

  .mission p {
    margin: 0;
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .mission small {
    color: var(--gray-10);
  }
</style>
