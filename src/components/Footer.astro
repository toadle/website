---
import { i18n, type Locale } from "../i18n";
import Center from "./Center.astro";

const today = new Date();
const currentPath = Astro.url.pathname;
const firstSegment = currentPath.split("/").filter(Boolean)[0];
const lang: Locale =
  firstSegment === "en" || firstSegment === "de" ? firstSegment : "de";
const t = i18n[lang];

const leftLinks = [
  { label: "About", href: lang === "de" ? "/de/about" : "/en/about" },
  { label: "Work", href: lang === "de" ? "/de/work" : "/en/work" },
  { label: "Now", href: lang === "de" ? "/de/now" : "/en/now" },
  { label: "Blog", href: lang === "de" ? "/de/blog" : "/en/blog" },
];

const rightLinks = [
  { label: "GitHub", href: "https://github.com" },
  { label: "LinkedIn", href: "https://www.linkedin.com" },
  { label: "RSS", href: "/rss.xml" },
  { label: "Email", href: "mailto:hello@toadle.me" },
];
---

<footer class="site-footer">
  <Center>
    <div class="inner">
    <div class="link-columns">
      <ul>
        {leftLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <ul>
        {rightLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <section class="mission">
      <h2>{lang === "de" ? "Mission" : "Mission"}</h2>
      <p>{t.home.intro}</p>
      <small>&copy; {today.getFullYear()} Tim Adler</small>
    </section>

    <div class="avatar-wrap" aria-hidden="true">
      <svg
        class="avatar"
        viewBox="0 0 16 16"
        shape-rendering="crispEdges"
        role="img"
        aria-label="Pixel avatar"
      >
        <rect x="0" y="0" width="16" height="16" class="bg" />
        <rect x="3" y="2" width="10" height="1" class="hair" />
        <rect x="2" y="3" width="12" height="2" class="hair" />
        <rect x="2" y="5" width="12" height="6" class="skin" />
        <rect x="4" y="7" width="2" height="1" class="eye" />
        <rect x="10" y="7" width="2" height="1" class="eye" />
        <rect x="5" y="9" width="6" height="1" class="mouth" />
        <rect x="1" y="11" width="14" height="3" class="shirt" />
      </svg>
    </div>
  </Center>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--gray-4);
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) 0;
    width: 100%;
  }

  .inner {
    display: grid;
    gap: var(--space-xl);

    @media (width >= 900px) {
      grid-template-columns: 1fr 1.3fr auto;
      align-items: start;
    }
  }

  .link-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s) var(--space-l);
  }

  .link-columns ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-xs);
  }

  .link-columns a {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .mission {
    display: grid;
    gap: var(--space-s);
    max-width: 48ch;
  }

  .mission h2 {
    font-size: var(--step-3);
  }

  .mission p {
    margin: 0;
    font-size: var(--step-1);
    line-height: var(--line-height-snug);
  }

  .mission small {
    color: var(--gray-10);
  }

  .avatar-wrap {
    border: 1px dashed var(--gray-6);
    border-radius: var(--radius-l);
    padding: var(--space-s);
    width: fit-content;
  }

  .avatar {
    width: 96px;
    height: 96px;
    display: block;
  }

  .bg {
    fill: var(--gray-2);
  }

  .hair {
    fill: var(--gray-11);
  }

  .skin {
    fill: var(--gray-5);
  }

  .eye {
    fill: var(--gray-12);
  }

  .mouth {
    fill: var(--gray-10);
  }

  .shirt {
    fill: var(--gray-8);
  }
</style>
