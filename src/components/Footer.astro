---
import { i18n, type Locale } from "../i18n";
import { Image } from "astro:assets";
import Center from "./Center.astro";
import avatarNormal from "../assets/avatar_normal.png";
import avatarFunny1 from "../assets/avatar_funny1.png";
import avatarFunny2 from "../assets/avatar_funny2.png";

const currentPath = Astro.url.pathname;
const firstSegment = currentPath.split("/").filter(Boolean)[0];
const lang: Locale =
  firstSegment === "en" || firstSegment === "de" ? firstSegment : "de";
const t = i18n[lang];

const leftLinks = [
  { label: "GitHub", href: "https://github.com/toadle" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/tim-adler-12ba11188/" },
  { label: "Mastodon", href: "https://mastodon.social/@toadle" },
  { label: "Twitter", href: "https://x.com/toadle" },
];

const rightLinks = [
  { label: "Instagram", href: "https://www.instagram.com/t.o.adler/" },
  { label: "Email", href: "mailto:hello@toadle.me" },
  { label: "Blog RSS", href: `/${lang}/blog/rss.xml` },
  { label: "Now RSS", href: `/${lang}/now/rss.xml` },
];

const footerText = t.footer;
const footerAvatarSources = [
  avatarNormal.src,
  avatarFunny1.src,
  avatarFunny2.src,
];
const legalLinks =
  lang === "en"
    ? [
        { label: "Privacy Policy", href: "/en/privacy" },
        { label: "Imprint", href: "/en/imprint" },
      ]
    : [
        { label: "Datenschutzerklärung", href: "/de/datenschutz" },
        { label: "Impressum", href: "/de/impressum" },
      ];
---

<footer class="site-footer">
  <Center>
    <div class="inner">
      <div class="links-block">
        <div class="link-columns">
          <ul>
            {leftLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
          <ul>
            {rightLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <section class="mission">
        <h3 class="mission-site-title">{footerText.siteTitle}</h3>
        <p class="mission-site-body">
          {footerText.siteBodyPrefix}<a href={`/${lang}`}>{footerText.siteOwnerLabel}</a>{footerText.siteBodySuffix}
        </p>
        <p class="mission-note">{footerText.note}</p>
      </section>

      <aside
        class="footer-avatar"
        aria-hidden="true"
        data-avatar-stamp
        data-avatar-sources={JSON.stringify(footerAvatarSources)}
      >
        <Image
          src={avatarNormal}
          alt=""
          width={96}
          height={96}
          class="footer-note-avatar"
          data-avatar-image
          draggable="false"
          loading="lazy"
          decoding="async"
        />
      </aside>
    </div>

    <nav class="legal-links" aria-label={lang === "en" ? "Legal" : "Rechtliches"}>
      {legalLinks.map((link, index) => (
        <>
          <a href={link.href}>{link.label}</a>
          {index < legalLinks.length - 1 && <span aria-hidden="true">·</span>}
        </>
      ))}
    </nav>
  </Center>
</footer>

<script is:inline>
  (() => {
    const stampNodes = document.querySelectorAll("[data-avatar-stamp]");

    for (const stampNode of stampNodes) {
      if (!(stampNode instanceof HTMLElement)) {
        continue;
      }

      const avatarImage = stampNode.querySelector("img[data-avatar-image]");
      const rawSources = stampNode.getAttribute("data-avatar-sources");

      if (!(avatarImage instanceof HTMLImageElement) || !rawSources) {
        continue;
      }

      let sources = [];
      try {
        const parsed = JSON.parse(rawSources);
        if (Array.isArray(parsed)) {
          sources = parsed.filter((source) => typeof source === "string");
        }
      } catch {
        sources = [];
      }

      if (sources.length === 0) {
        continue;
      }

      let sourceIndex = 0;
      avatarImage.src = sources[sourceIndex] ?? avatarImage.src;

      const clearPressed = () => {
        stampNode.classList.remove("is-pressed");
      };

      const onPointerDown = (event) => {
        if (event.pointerType !== "mouse" && event.pointerType !== "touch") {
          return;
        }

        if (event.pointerType === "mouse" && event.button !== 0) {
          return;
        }

        stampNode.classList.add("is-pressed");
        try {
          stampNode.setPointerCapture(event.pointerId);
        } catch {
          // Ignore unsupported pointer capture in older engines.
        }
      };

      const onPointerUp = (event) => {
        if (!stampNode.classList.contains("is-pressed")) {
          return;
        }

        clearPressed();

        if (event.pointerType !== "mouse" && event.pointerType !== "touch") {
          return;
        }

        sourceIndex = (sourceIndex + 1) % sources.length;
        avatarImage.src = sources[sourceIndex];

        try {
          stampNode.releasePointerCapture(event.pointerId);
        } catch {
          // Ignore unsupported pointer capture release.
        }
      };

      stampNode.addEventListener("pointerdown", onPointerDown);
      stampNode.addEventListener("pointerup", onPointerUp);
      stampNode.addEventListener("pointercancel", clearPressed);
      stampNode.addEventListener("pointerleave", clearPressed);
    }
  })();
</script>

<style>
  .site-footer {
    border-top: 1px solid var(--gray-4);
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) 0;
    width: 100%;
  }

  .inner {
    display: grid;
    gap: var(--space-xl);
    margin-bottom: var(--space-l);

    @media (width >= 900px) {
      grid-template-columns: 1fr 1.3fr auto;
      align-items: start;
    }
  }

  .links-block {
    display: grid;
    gap: var(--space-m);
    align-content: start;
  }

  .link-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s) var(--space-l);
  }

  .link-columns ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-xs);
  }

  .link-columns a {
    text-decoration: underline;
    text-underline-offset: 0.12em;
    font-size: var(--step-0);
    line-height: var(--line-height-body);
  }

  .mission {
    display: grid;
    gap: var(--space-s);
    max-width: 48ch;
  }

  .mission h2 {
    font-size: var(--step-3);
  }

  .mission p {
    margin: 0;
  }

  .mission-site-title {
    font-size: var(--step-1);
    font-weight: var(--font-weight-bold);
    color: var(--gray-12);
    margin: 0;
  }

  .mission-site-body {
    font-size: var(--step-0);
    color: var(--gray-12);
    margin: 0;
    line-height: var(--line-height-body);
  }

  .mission-note {
    margin: 0;
    color: var(--gray-12);
    font-size: var(--step-0);
    line-height: var(--line-height-body);
  }

  .mission small {
    font-size: var(--step--1);
    color: var(--gray-12);
  }

  .footer-avatar {
    --stamp-r: 5px;
    --stamp-s: 14px;

    justify-self: start;
    align-self: start;
    background: var(--gray-3);
    padding: 0.5rem;
    display: inline-grid;
    user-select: none;
    touch-action: manipulation;
    transition: transform 120ms ease, box-shadow 120ms ease;

    /* Briefmarken-Stanzeffekt: 4 Lagen, je eine Kante, via intersect kombiniert */
    -webkit-mask:
      radial-gradient(circle at 50% 0%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / var(--stamp-s) 100%,
      radial-gradient(circle at 50% 100%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / var(--stamp-s) 100%,
      radial-gradient(circle at 0% 50%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / 100% var(--stamp-s),
      radial-gradient(circle at 100% 50%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / 100% var(--stamp-s);
    -webkit-mask-composite: source-in, source-in, source-in;

    mask:
      radial-gradient(circle at 50% 0%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / var(--stamp-s) 100%,
      radial-gradient(circle at 50% 100%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / var(--stamp-s) 100%,
      radial-gradient(circle at 0% 50%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / 100% var(--stamp-s),
      radial-gradient(circle at 100% 50%, #0000 var(--stamp-r), #000 calc(var(--stamp-r) + .5px))
        0 0 / 100% var(--stamp-s);
    mask-composite: intersect;

    @media (width >= 900px) {
      justify-self: end;
    }
  }

  .footer-avatar:hover {
    cursor: pointer;
  }

  .footer-avatar.is-pressed {
    transform: translateY(1px) scale(0.99);
    box-shadow: inset 0 1px 2px color-mix(in oklab, var(--gray-12) 20%, transparent);
  }

  .footer-note-avatar {
    inline-size: 6rem;
    block-size: 6rem;
    object-fit: cover;
    object-position: top;
    image-rendering: pixelated;
    display: block;
    pointer-events: none;
  }

  .legal-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs);
    color: var(--gray-10);
    font-size: var(--step--1);
  }

  .legal-links a {
    color: var(--gray-10);
    text-decoration-color: var(--gray-8);
  }

  .legal-links a:hover {
    color: var(--gray-12);
    text-decoration-color: var(--gray-10);
  }

  .legal-links span {
    color: var(--gray-8);
  }
</style>
